###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_this_to_a_random_32_char_string_here
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format: pgsql://user:password@host:port/dbname
DATABASE_URL="postgresql://doshka:doshka_secret@postgres:5432/doshka?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=doshka_jwt_passphrase
JWT_TOKEN_TTL=3600
###< lexik/jwt-authentication-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=smtp://mailpit:1025
MAILER_FROM_ADDRESS=noreply@doshka-app.local
MAILER_FROM_NAME="Doshka App"
###< symfony/mailer ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

# Redis
REDIS_URL=redis://redis:6379

# App settings
POSTGRES_DB=doshka
POSTGRES_USER=doshka
POSTGRES_PASSWORD=doshka_secret
